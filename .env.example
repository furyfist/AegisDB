# Copy this file to `.env` and fill in the real values for your environment.

# OpenMetadata
OM_HOST=http://localhost:8585
OM_ADMIN_EMAIL=admin@open-metadata.org
OM_ADMIN_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM_NAME=aegisdb:events
REDIS_REPAIR_STREAM=aegisdb:repair
REDIS_ESCALATION_STREAM=aegisdb:escalation
REDIS_APPLY_STREAM=aegisdb:apply
REDIS_CONSUMER_GROUP=aegisdb-agents
REDIS_CONSUMER_NAME=diagnosis-agent-1

# App
APP_HOST=0.0.0.0
APP_PORT=8000
WEBHOOK_SECRET=change_me

# LLM
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION=aegisdb_fixes

# Diagnosis
CONFIDENCE_THRESHOLD=0.70

# Target database monitored by AegisDB
TARGET_DB_HOST=localhost
TARGET_DB_PORT=5433
TARGET_DB_NAME=aegisdb
TARGET_DB_USER=aegisdb_user
TARGET_DB_PASSWORD=aegisdb_pass

# Sandbox
SANDBOX_MAX_RETRIES=3
SANDBOX_SAMPLE_ROWS=500
SANDBOX_TIMEOUT_SECONDS=60

# Apply
DRY_RUN=true
APPLY_STATEMENT_TIMEOUT_MS=30000
POST_APPLY_VERIFY=true
